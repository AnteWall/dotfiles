# === Window focus ===
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# === Disable native macOS hide shortcuts ===
cmd - h : true
cmd + alt - h : true

# === Window swap ===
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

# === Window warp (move into split) ===
shift + ctrl + alt - h : yabai -m window --warp west
shift + ctrl + alt - j : yabai -m window --warp south
shift + ctrl + alt - k : yabai -m window --warp north
shift + ctrl + alt - l : yabai -m window --warp east

# === Window resize ===
ctrl + alt - h : yabai -m window --resize left:-50:0
ctrl + alt - j : yabai -m window --resize bottom:0:50
ctrl + alt - k : yabai -m window --resize top:0:-50
ctrl + alt - l : yabai -m window --resize right:50:0

# === Toggle window properties ===
alt - f : yabai -m window --toggle zoom-fullscreen
shift + alt - f : yabai -m window --toggle native-fullscreen
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# === Space focus ===
ctrl + alt - 1 : ~/.local/bin/yabai-space focus 1
ctrl + alt - 2 : ~/.local/bin/yabai-space focus 2
ctrl + alt - 3 : ~/.local/bin/yabai-space focus 3
ctrl + alt - 4 : ~/.local/bin/yabai-space focus 4
ctrl + alt - 5 : ~/.local/bin/yabai-space focus 5
ctrl + alt - 6 : ~/.local/bin/yabai-space focus 6
ctrl + alt - 7 : ~/.local/bin/yabai-space focus 7
ctrl + alt - 8 : ~/.local/bin/yabai-space focus 8
ctrl + alt - 9 : ~/.local/bin/yabai-space focus 9

# === Space create/destroy ===
ctrl + alt - n : yabai -m space --create
ctrl + alt - x : yabai -m space --destroy

# === Move window to space ===
shift + ctrl + alt - 1 : ~/.local/bin/yabai-space move 1
shift + ctrl + alt - 2 : ~/.local/bin/yabai-space move 2
shift + ctrl + alt - 3 : ~/.local/bin/yabai-space move 3
shift + ctrl + alt - 4 : ~/.local/bin/yabai-space move 4
shift + ctrl + alt - 5 : ~/.local/bin/yabai-space move 5
shift + ctrl + alt - 6 : ~/.local/bin/yabai-space move 6
shift + ctrl + alt - 7 : ~/.local/bin/yabai-space move 7
shift + ctrl + alt - 8 : ~/.local/bin/yabai-space move 8
shift + ctrl + alt - 9 : ~/.local/bin/yabai-space move 9

# === Balance tree ===
shift + alt - 0 : yabai -m space --balance

# === Rotate tree ===
alt - r : yabai -m space --rotate 90

# === Mirror tree ===
alt - x : yabai -m space --mirror x-axis
alt - y : yabai -m space --mirror y-axis

# === Toggle split direction ===
alt - e : yabai -m window --toggle split

# === Restart yabai ===
ctrl + alt + cmd - r : yabai --restart-service
